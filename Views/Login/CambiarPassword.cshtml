@using OEED_ITT.Helpers;

@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Cambio de Contraseña</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        body {
            background: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.6)), url('/images/Fondo.jpg') no-repeat center center fixed;
            background-size: cover;
            color: #FAFFF9;
            font-family: Arial, sans-serif;
            display: flex;
            justify-content: center;
            align-items: center;
            height: 100vh;
            margin: 0;
        }

        .form-container {
            background-color: rgba(83, 112, 82, 0.9);
            padding: 40px;
            border-radius: 10px;
            box-shadow: 0px 0px 20px rgba(0, 0, 0, 0.5);
            max-width: 500px;
            width: 100%;
            text-align: center;
            margin: 20px;
        }

        .form-header img {
            max-width: 150px;
            height: auto;
            margin-bottom: 20px;
        }

        .form-header h1 {
            color: #FAFFF9;
            font-size: 24px;
            margin-bottom: 20px;
            font-weight: bold;
        }

        .form-group {
            margin-bottom: 20px;
        }

        label {
            color: #FAFFF9;
            font-weight: bold;
        }

        .form-control {
            background-color: #EAF6EA;
            color: #537052;
            border: 1px solid #475148;
        }

            .form-control:focus {
                background-color: #FAFFF9;
                color: #537052;
                border-color: #475148;
                box-shadow: none;
            }

        .btn-primary {
            background-color: #3e6f3e;
            border-color: #537052;
            color: #FAFFF9;
            padding: 10px 20px;
            font-size: 16px;
            border-radius: 5px;
            cursor: pointer;
            width: 100%;
            transition: background-color 0.3s, border-color 0.3s, color 0.3s;
        }

            .btn-primary:hover {
                background-color: #537052;
                border-color: #3e6f3e;
                color: #FFFFFF;
            }

        .nav-llink {
            color: #FAFFF9;
        }

        .text-danger {
            color: white;
        }
    </style>
</head>
<body>
    <div class="form-container">
        <div class="form-header">
            <img src="/images/LogoDef_GO.png" alt="Logo OEED" />
            <h1>Organizador Escolar de Eventos Digital</h1>
        </div>

        <h2 class="text-white">Cambio de Contraseña</h2>

        <form asp-action="CambioPassword" asp-controller="Login" method="post">
            <div class="form-group">
                <label for="noCtrl">Ingrese su No. control:</label>
                <input type="text" id="noCtrl" name="noCtrl" class="form-control" />
            </div>
            <div class="form-group">
                <label for="oldP">Ingrese su contraseña actual:</label>
                <input type="password" id="oldP" name="oldP" class="form-control" />
            </div>
            <div class="form-group">
                <label for="newP">Ingrese su nueva contraseña:</label>
                <input type="password" id="newP" name="newP" class="form-control" />
            </div>
            <button type="submit" class="btn btn-primary">Actualizar contraseña</button>
            <div style=" color: white">@UsuarioG.mensajeError</div>
            @if (UsuarioG.mensajeError != null)
            {                
                UsuarioG.vaciarMensaje();
            }
        </form>

        <a class="btn btn-primary" asp-area="" asp-controller="Login" asp-action="Index">Volver al inicio</a>
    </div>

    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
