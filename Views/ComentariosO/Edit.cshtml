@model OEED_ITT.Models.Comentario

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Edit</title>
</head>
<body>

<h4>Comentario</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdComentario" />
            <div class="form-group">
                <label asp-for="AsuntoComentario" class="control-label"></label>
                <input asp-for="AsuntoComentario" class="form-control" />
                <span asp-validation-for="AsuntoComentario" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DescripcionComentario" class="control-label"></label>
                <input asp-for="DescripcionComentario" class="form-control" />
                <span asp-validation-for="DescripcionComentario" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FechaComentario" class="control-label"></label>
                <input asp-for="FechaComentario" class="form-control" />
                <span asp-validation-for="FechaComentario" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdUsuario" class="control-label"></label>
                <select asp-for="IdUsuario" class="form-control" asp-items="ViewBag.IdUsuario"></select>
                <span asp-validation-for="IdUsuario" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="IdEvento" class="control-label"></label>
                <select asp-for="IdEvento" class="form-control" asp-items="ViewBag.IdEvento"></select>
                <span asp-validation-for="IdEvento" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

</body>
</html>
