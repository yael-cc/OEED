<!DOCTYPE html>

@{
    Layout = "~/Views/Shared/_LayoutO.cshtml";
}

<html>
<head>
    <title>Estadísticas en su departamento</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="container mt-5">
        <h1 class="mb-4">Estadísticas del Departamento</h1>
        <div class="row">
            <div class="col-md-6 mb-4">
                <canvas id="eventosChart"></canvas>
            </div>
            <div class="col-md-6 mb-4">
                <canvas id="asistenciasChart"></canvas>
            </div>
        </div>
    </div>

    <script>
        const eventosData = {
            labels: ['Realizados', 'Finalizados', 'Cancelados', 'En Progreso/Futuros'],
            datasets: [{
                label: 'Eventos',
                data: [
        @ViewData["eventosRealizados"],
        @ViewData["eventosFinalizados"],
        @ViewData["eventosCancelados"],
        @ViewData["eventosProgresoOFuturos"]
                        ],
                backgroundColor: ['#007bff', '#28a745', '#dc3545', '#ffc107'],
                borderColor: ['#007bff', '#28a745', '#dc3545', '#ffc107'],
                borderWidth: 1
            }]
        };

        const asistenciasData = {
            labels: ['Total Inscripciones', 'Asistencias en eventos', 'Asistencias propias del departamento', 'Asistencias de otros Departamentos'],
            datasets: [{
                label: 'Asistencias',
                data: [
        @ViewData["totalInscripciones"],
        @ViewData["totalAsistenciasEventosDepartamento"],
        @ViewData["asistenciasDepartamentoEnSusEventos"],
        @ViewData["asistenciasOtroDepartamento"]
                        ],
                backgroundColor: ['#17a2b8', '#6f42c1', '#fd7e14', '#343a40'],
                borderColor: ['#17a2b8', '#6f42c1', '#fd7e14', '#343a40'],
                borderWidth: 1
            }]
        };

        const eventosConfig = {
            type: 'bar',
            data: eventosData,
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        };

        const asistenciasConfig = {
            type: 'bar',
            data: asistenciasData,
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        };

        new Chart(document.getElementById('eventosChart'), eventosConfig);
        new Chart(document.getElementById('asistenciasChart'), asistenciasConfig);
    </script>
</body>
</html>
