@model IEnumerable<OEED_ITT.Models.Evento>

<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lista de Eventos con Asistencia</title>
    <link rel="stylesheet" href="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css">
    <style>
        /* Estilos CSS adicionales */

        body {
            font-family: Arial, sans-serif;
            background-color: #f8f9fa; /* Color de fondo del cuerpo */
            color: #343a40; /* Color de texto principal */
        }

        .containerF {
            max-width: 1200px; /* Ancho máximo del contenido */
            margin-top: 50px; /* Espaciado superior */
        }

        .table img {
            max-width: 150px; /* Reducir el tamaño de la imagen para que quepa mejor en la tabla */
            max-height: 150px;
            border-radius: 5px; /* Agregar bordes redondeados a las imágenes */
        }

        .table-striped tbody tr:nth-of-type(odd) {
            background-color: #f5f5f5; /* Fondos alternos para filas en la tabla */
        }

        .button-details {
            background-color: #007bff; /* Color de fondo del botón */
            color: #ffffff; /* Color de texto del botón */
            padding: 8px 16px;
            border: none;
            border-radius: 5px;
            text-decoration: none;
            cursor: pointer;
            display: inline-block;
            font-size: 16px; /* Tamaño de fuente para los botones */
            transition: background-color 0.3s ease; /* Transición suave para el color de fondo */
        }

        .button-details:hover {
            background-color: #0056b3; /* Color de fondo al pasar el cursor */
        }

        .alert-info {
            background-color: #d1ecf1; /* Color de fondo para la alerta informativa */
            color: #0c5460; /* Color de texto para la alerta informativa */
            border-color: #bee5eb; /* Color del borde para la alerta informativa */
        }
    </style>
</head>
<body>
    <div class="containerF">
        <h1 class="mt-4 mb-3">Lista de Eventos con Asistencia</h1>
        <div class="row">
            <div class="col-lg-12">
                @if (Model.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-bordered table-hover">
                            <thead class="thead-dark">
                                <tr>
                                    <th scope="col">Imagen</th>
                                    <th scope="col">Nombre</th>
                                    <th scope="col">Fecha</th>
                                    <th scope="col">Opciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var evento in Model)
                                {
                                    <tr>
                                        <td>
                                            @if (!string.IsNullOrEmpty(evento.Imagen))
                                            {
                                                if (Uri.TryCreate(evento.Imagen, UriKind.Absolute, out Uri imageUrl))
                                                {
                                                    // Si la cadena es una URL válida, mostrarla como una imagen externa
                                                    <img src="@evento.Imagen" alt="Imagen del Evento" />
                                                }
                                                else
                                                {
                                                    // Si la cadena no es una URL válida, determinar el tipo MIME según los prefijos comunes
                                                    var imageDataPrefix = evento.Imagen.Substring(0, 5);

                                                    string mimeType = "image/jpeg"; // Asumir JPEG por defecto
                                                    if (imageDataPrefix.Contains("/9j/4")) // Común prefijo para JPEG
                                                    {
                                                        mimeType = "image/jpeg";
                                                    }
                                                    else if (imageDataPrefix.Contains("iVBOR")) // Común prefijo para PNG
                                                    {
                                                        mimeType = "image/png";
                                                    }
                                                    else if (imageDataPrefix.Contains("UklGR")) // Común prefijo para WebP
                                                    {
                                                        mimeType = "image/webp";
                                                    }
                                                    else if (imageDataPrefix.Contains("AAAAI")) // Común prefijo para AVIF
                                                    {
                                                        mimeType = "image/avif";
                                                    }

                                                    <img src="data:@mimeType;base64,@evento.Imagen" alt="Imagen del Evento" />
                                                }
                                            }
                                        </td>
                                        <td>@Html.DisplayFor(modelItem => evento.NombreEvento)</td>
                                        <td>@Html.DisplayFor(modelItem => evento.FechaEvento)</td>
                                        <td>
                                            <a asp-controller="Comentarios" asp-action="Create" asp-route-idEvento="@evento.IdEvento" class="button-details">Hacer queja o sugerencia</a> <br>
                                            <a asp-controller="Comentarios" asp-action="Index" asp-route-idEvento="@evento.IdEvento" class="button-details mt-2">Ver mis comentarios</a>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="alert alert-info" role="alert">
                        No hay eventos con asistencia para mostrar.
                    </div>
                }
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js"></script>
</body>
</html>