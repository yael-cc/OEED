@model IEnumerable<OEED_ITT.Models.Inscripcion>

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Index</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #EAF6EA;
            color: #537052;
            margin: 0;
            padding: 0;
        }

        .container {
            max-width: 1200px;
            margin: 20px auto;
            padding: 20px;
            background-color: #FAFFF9;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
        }

        h2 {
            color: #537052;
            margin-bottom: 20px;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }

        th, td {
            padding: 10px;
            border: 1px solid #859C80;
        }

        th {
            background-color: #537052;
            color: #fff;
            font-weight: bold;
            text-align: left;
        }

        tr:nth-child(even) {
            background-color: #EAF6EA;
        }

        tr:hover {
            background-color: #FAFFF9;
        }

        img {
            max-width: 100px;
            height: auto;
            display: block;
            margin: auto;
        }

        .button-details {
            background-color: #475148;
            color: #fff;
            padding: 5px 10px;
            border: none;
            border-radius: 5px;
            text-decoration: none;
        }

            .button-details:hover {
                background-color: #859C80;
            }
    </style>
</head>
<body>
    <div class="container">
        <h2>Lista de Inscripciones</h2>
        <table>
            <thead>
                <tr>
                    <th>Fecha de registro</th>
                    <th>Estado</th>
                    <th>Evento</th>
                    <th>Usuario</th>
                    <th>Imagen</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.HoraInscripcion)</td>
                        <td>@Html.DisplayFor(modelItem => item.oEstadoI.NombreEstadoInscripcion)</td>
                        <td>@Html.DisplayFor(modelItem => item.OEvento.NombreEvento)</td>
                        <td>@Html.DisplayFor(modelItem => item.oUsuario.IdUsuario)</td>
                        <td>
                            @if (!string.IsNullOrEmpty(item.OEvento.Imagen))
                            {
                                <img src="@item.OEvento.Imagen" alt="Imagen del evento" />
                            }
                            else
                            {
                                <span>No hay imagen disponible</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-controller="Evento" asp-route-id="@item.OEvento.IdEvento" class="button-details">Ver evento</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</body>
</html>
