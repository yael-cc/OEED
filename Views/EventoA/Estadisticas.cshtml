@{
    Layout = "~/Views/Shared/_LayoutA.cshtml";
    ViewData["Title"] = "Estadísticas en su departamento";
    var eventosRealizados = (int)ViewData["eventosRealizados"];
    var eventosFinalizados = (int)ViewData["eventosFinalizados"];
    var eventosCancelados = (int)ViewData["eventosCancelados"];
    var eventosProgresoOFuturos = (int)ViewData["eventosProgresoOFuturos"];
    var totalInscripciones = (int)ViewData["totalInscripciones"];
    var totalAsistenciasEventosDepartamento = (int)ViewData["totalAsistenciasEventosDepartamento"];
    var asistenciasDepartamentoEnSusEventos = (int)ViewData["asistenciasDepartamentoEnSusEventos"];
    var asistenciasOtroDepartamento = (int)ViewData["asistenciasOtroDepartamento"];
    var departamentos = (SelectList)ViewData["departamentos"];
    var idDepartamentoSeleccionado = ViewData["idDepartamentoSeleccionado"] as string;
}

<!DOCTYPE html>
<html>
<head>
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
</head>
<body>
    <div class="container mt-5">
        <h1 class="mb-4">Estadísticas del Departamento</h1>

        <!-- Formulario de selección de departamento -->
        <form method="get" action="@Url.Action("Estadisticas", "EventoA")" class="mb-4">
            <div class="form-group">
                <label for="idDepartamento">Selecciona un departamento:</label>
                <select id="idDepartamento" name="idDepartamento" class="form-control">
                    @foreach (var departamento in departamentos)
                    {
                        <option value="@departamento.Value" selected="@(departamento.Value == idDepartamentoSeleccionado)">
                            @departamento.Text
                        </option>
                    }
                </select>
            </div>
            <button type="submit" class="btn btn-primary mt-2">Mostrar estadísticas</button>
        </form>

        <div class="row">
            <div class="col-md-6 mb-4">
                <canvas id="eventosChart"></canvas>
            </div>
            <div class="col-md-6 mb-4">
                <canvas id="asistenciasChart"></canvas>
            </div>
        </div>
    </div>

    <script>
        const eventosData = {
            labels: ['Realizados', 'Finalizados', 'Cancelados', 'En Progreso/Futuros'],
            datasets: [{
                label: 'Eventos',
                data: [
                    @eventosRealizados,
                    @eventosFinalizados,
                    @eventosCancelados,
                    @eventosProgresoOFuturos
                ],
                backgroundColor: ['#007bff', '#28a745', '#dc3545', '#ffc107'],
                borderColor: ['#007bff', '#28a745', '#dc3545', '#ffc107'],
                borderWidth: 1
            }]
        };

        const asistenciasData = {
            labels: ['Total Inscripciones', 'Asistencias en eventos', 'Asistencias propias del departamento', 'Asistencias de otros Departamentos'],
            datasets: [{
                label: 'Asistencias',
                data: [
                    @totalInscripciones,
                    @totalAsistenciasEventosDepartamento,
                    @asistenciasDepartamentoEnSusEventos,
                    @asistenciasOtroDepartamento
                ],
                backgroundColor: ['#17a2b8', '#6f42c1', '#fd7e14', '#343a40'],
                borderColor: ['#17a2b8', '#6f42c1', '#fd7e14', '#343a40'],
                borderWidth: 1
            }]
        };

        const eventosConfig = {
            type: 'bar',
            data: eventosData,
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        };

        const asistenciasConfig = {
            type: 'bar',
            data: asistenciasData,
            options: {
                responsive: true,
                scales: {
                    y: {
                        beginAtZero: true
                    }
                }
            }
        };

        new Chart(document.getElementById('eventosChart'), eventosConfig);
        new Chart(document.getElementById('asistenciasChart'), asistenciasConfig);
    </script>
</body>
</html>