@model IEnumerable<OEED_ITT.Models.Inscripcion>

<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Lista de Inscripciones</title>
    <link href="https://maxcdn.bootstrapcdn.com/bootstrap/4.5.2/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #EAF6EA;
            color: #537052;
        }

        .containerf {
            background-color: #FAFFF9;
            border-radius: 5px;
            box-shadow: 0 0 10px rgba(0, 0, 0, 0.1);
            padding: 20px;
            margin-top: 20px;
        }

        h2 {
            color: #537052;
            margin-bottom: 20px;
            text-align: center;
        }

        .table th {
            background-color: #537052;
            color: #fff;
            text-align: left;
        }

        .table tr:nth-child(even) {
            background-color: #EAF6EA;
        }

        .table tr:hover {
            background-color: #FAFFF9;
        }

        .button-details {
            background-color: #475148;
            color: #fff;
            padding: 5px 10px;
            border: none;
            border-radius: 5px;
            text-decoration: none;
        }

            .button-details:hover {
                background-color: #859C80;
            }
    </style>
</head>
<body>
    <div class="container mt-5">
        <div class="containerf">
            <h2>Lista de Inscripciones</h2>
            <div class="table-responsive">
                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Fecha de registro</th>
                            <th>Estado</th>
                            <th>Evento</th>
                            <th>Imagen</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>@Html.DisplayFor(modelItem => item.HoraInscripcion)</td>
                                <td>@Html.DisplayFor(modelItem => item.oEstadoI.NombreEstadoInscripcion)</td>
                                <td>@Html.DisplayFor(modelItem => item.OEvento.NombreEvento)</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.OEvento.Imagen))
                                    {
                                        if (Uri.TryCreate(item.OEvento.Imagen, UriKind.Absolute, out Uri imageUrl))
                                        {
                                            // Si la cadena es una URL válida, mostrarla como una imagen externa
                                            <img src="@item.OEvento.Imagen" alt="Imagen del Evento" width="150" height="75" />
                                        }
                                        else
                                        {
                                            // Si la cadena no es una URL válida, determinar el tipo MIME según los prefijos comunes
                                            var imageDataPrefix = item.OEvento.Imagen.Substring(0, 5);

                                            string mimeType = "image/jpeg"; // Asumir JPEG por defecto
                                            if (imageDataPrefix.Contains("/9j/4")) // Común prefijo para JPEG
                                            {
                                                mimeType = "image/jpeg";
                                            }
                                            else if (imageDataPrefix.Contains("iVBOR")) // Común prefijo para PNG
                                            {
                                                mimeType = "image/png";
                                            }
                                            else if (imageDataPrefix.Contains("UklGR")) // Común prefijo para WebP
                                            {
                                                mimeType = "image/webp";
                                            }
                                            else if (imageDataPrefix.Contains("AAAAI")) // Común prefijo para AVIF
                                            {
                                                mimeType = "image/avif";
                                            }

                                            <img src="data:@mimeType;base64,@item.OEvento.Imagen" alt="Imagen del Evento" width="150" height="75" />
                                        }
                                    }
                                </td>
                                <td>
                                    <a asp-action="Details" asp-controller="Evento" asp-route-id="@item.OEvento.IdEvento" class="button-details">Ver evento</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script src="https://code.jquery.com/jquery-3.5.1.slim.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.5.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>